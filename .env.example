# Copy to .env and fill this before running `make real-ingest`.
ETHERSCAN_API_KEY=

# Keep these low for a laptop-friendly first run.
ETHERSCAN_CHAIN_ID=1
REAL_MAX_WALLETS=10
REAL_MAX_TX_PER_WALLET=50
REAL_BATCH_SIZE=500
REAL_WORKERS=1
REAL_HTTP_RETRIES=3
REAL_PRICE_MAX_TOKENS=5
REAL_PRICE_BATCH_SIZE=5
REAL_ENABLE_PRICE_LOOKUP=true
REAL_SLEEP_SECONDS=1.0
REAL_ENABLE_SWAPS=true
REAL_MAX_RECEIPTS_PER_WALLET=20

# Optional: comma-separated wallet addresses.
# If empty, real_ingest uses Postgres watchlist_wallets, then raw.wallet_watchlist fallback.
REAL_WALLETS=

# Optional: discover a larger real watchlist from Etherscan counterparties.
# Defaults to REAL_WALLETS as seed wallets when SEED_WALLETS is empty.
SEED_WALLETS=
SEED_TARGET_WALLETS=200
SEED_MAX_TRANSFERS_PER_SEED=1000
SEED_SLEEP_SECONDS=1.0
SEED_WATCHLIST_NAME=Etherscan counterparty seeds

# Optional block window.
REAL_START_BLOCK=0
REAL_END_BLOCK=99999999

# Local candidate discovery from raw.dex_transactions.
DISCOVERY_LOOKBACK_DAYS=30
DISCOVERY_TOP_N=50
DISCOVERY_MIN_TX=5
DISCOVERY_MIN_TOKENS=2
DISCOVERY_SOURCE=local_raw_score
DISCOVERY_EVENT_SOURCE=all
DISCOVERY_WATCHLIST_NAME=Auto discovery

# Hourly-ish token price refresh from recently seen raw events.
PRICE_LOOKBACK_DAYS=30
PRICE_MAX_TOKENS=20
PRICE_BATCH_SIZE=5
PRICE_SLEEP_SECONDS=2.0
PRICE_REFRESH_HOURS=12
PRICE_SOURCE=coingecko-price-job
PRICE_EVENT_SOURCE=all

# Wallet-wallet similarity graph from ClickHouse wallet-token edges.
GRAPH_MAX_WALLETS=300
GRAPH_MAX_TOKENS_PER_WALLET=60
GRAPH_MIN_COMMON_TOKENS=2
GRAPH_TOP_EDGES=1000
GRAPH_LOOKBACK_DAYS=30
GRAPH_DROP_NOISY_TOKENS=false
GRAPH_TRUNCATE_BEFORE_INSERT=true

# Token-token transition graph and route recommendations.
TOKEN_PATH_LOOKBACK_DAYS=30
TOKEN_PATH_MAX_EVENTS=50000
TOKEN_PATH_MIN_TRANSITIONS=3
TOKEN_PATH_MIN_WALLETS=2
TOKEN_PATH_TOP_EDGES=500
TOKEN_PATH_TOP_ROUTES=50
TOKEN_PATH_MAX_HOPS=4
